generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ResumeAnalysis {
  id           String   @id @default(cuid())
  userId       String
  fileName     String
  role         String
  atsScore     Int
  resumeText   String
  analysisData Json
  createdAt    DateTime @default(now())
}